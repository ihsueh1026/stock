# macOS
.DS_Store

# LibreOffice/Office lock files
.~lock.*#
~$*

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor
.vscode/
.idea/

# Claude Code local config
.claude/

# Backtest long-history data — regenerate via `python -m backtest.prefetch`
backtest/data/

# Per-user runtime accumulation. forward_log captures chip emissions
# day-of and back-fills alpha at maturity; news_log captures Yahoo
# Finance article + sentiment annotations (updated manually via Claude
# conversation). Both are local datasets unique to each user, not source.
stock_web/forward_log.jsonl
stock_web/news_log.jsonl

# launchd job logs (generated by tools/launchd/install*.sh + the
# scheduled jobs). Per-user runtime data.
tools/launchd/news-update.log
tools/launchd/watchlist-refresh.log

# Margin / SBL daily dumps — exempt from the 7-day cache purge (see
# _PURGE_EXEMPT_PREFIXES in app.py) so they accumulate to feed the
# 60-day 籌碼面 gauge + backtest studies. Per-user runtime data,
# regenerate via `python3 -m backtest.prefetch_margin_sbl`.
stock_web/cache/margin_*.json
stock_web/cache/sbl_*.json
